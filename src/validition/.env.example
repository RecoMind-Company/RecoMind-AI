# ===========================================
# Validation - Environment Variables
# ===========================================

# App Configuration
APP_NAME=validation
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8004
API_PREFIX=/api/v1
ROOT_PATH=/validation
ALLOWED_ORIGINS=*

# Service Authentication
SERVICE_API_KEY=your-service-api-key-here

# ===========================================
# LLM Configuration (Groq)
# ===========================================
GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# ===========================================
# .NET Backend API
# ===========================================
DOTNET_API_BASE_URL=https://api.recomind.site/api
DOTNET_AUTH_ENDPOINT=Authentication/login
DOTNET_COMPANY_ENDPOINT=Companies/GetByCompanyId/{company_id}
DOTNET_REPORTS_ENDPOINT=Report/all/{team_id}?limit={limit}

# Authentication credentials for .NET API
AUTH_EMAIL=your-auth-email@example.com
AUTH_PASSWORD=your-auth-password

# Report retrieval configuration
REPORT_LIMIT=2

# ===========================================
# Search Configuration (Precedent Engine)
# ===========================================
SERPER_API_KEY=your-serper-api-key-here
SEARCH_TIMEOUT=10
SEARCH_MAX_WORKERS=4
MIN_PRECEDENT_CASES=3
MAX_PRECEDENT_CASES=7
TARGET_PRECEDENT_CASES=5

# ===========================================
# Celery & Redis Configuration
# ===========================================
REDIS_HOST=validation-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://validation-redis:6379/0

CELERY_BROKER_URL=redis://validation-redis:6379/0
CELERY_RESULT_BACKEND=redis://validation-redis:6379/0
CELERY_QUEUE_NAME=validation_queue

# ===========================================
# Timeouts & Rate Limiting
# ===========================================
REQUEST_TIMEOUT=120
AUTH_TOKEN_CACHE_TTL=3600
