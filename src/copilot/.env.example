# ===========================================
# RecoMind Copilot - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# LLM Configuration (OpenRouter)
# ===========================================
crewai_LLM_MODEL=openrouter/*******
BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your_openrouter_api_key_here

# ===========================================
# Vector/Metadata Database (PostgreSQL with pgvector)
# ===========================================
VECTOR_DB_HOST=your_supabase_host.supabase.com
VECTOR_DB_USER=postgres.your_project_id
VECTOR_DB_PASSWORD=your_password
VECTOR_DB_NAME=postgres

# ===========================================
# Celery / Redis Configuration
# ===========================================
CELERY_BROKER_URL=redis://copilot-redis:6379/0

# ===========================================
# Environment Settings
# ===========================================
# development = shows /docs, production = hides /docs
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
# Use * for development, specific domains for production
ALLOWED_ORIGINS=*
