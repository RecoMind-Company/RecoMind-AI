# ===========================================
# Planning Board - Environment Variables
# ===========================================

# App Configuration
APP_NAME=planning-board
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Service Authentication
SERVICE_API_KEY=your-service-api-key-here

# ===========================================
# LLM Configuration (OpenRouter)
# ===========================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=openai/gpt-4o  # or anthropic/claude-3.5-sonnet

# ===========================================
# .NET Backend API (للموظفين)
# ===========================================
DOTNET_API_BASE_URL=http://localhost:5000
DOTNET_API_TOKEN=your-dotnet-service-token

# ===========================================
# Celery & Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# Rate Limiting & Timeouts
# ===========================================
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
REQUEST_TIMEOUT=120
