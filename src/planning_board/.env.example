# ===========================================
# Planning Board - Environment Variables
# ===========================================

# App Configuration
APP_NAME=planning-board
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8003
API_PREFIX=/api/v1
ROOT_PATH=/planning_board
ALLOWED_ORIGINS=*

# Service Authentication
SERVICE_API_KEY=your-service-api-key-here

# ===========================================
# LLM Configuration (OpenRouter)
# ===========================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=openai/gpt-4o  # or anthropic/claude-3.5-sonnet

# ===========================================
# .NET Backend API (للموظفين)
# ===========================================
DOTNET_API_BASE_URL=https://api.recomind.site/api
DOTNET_TEAM_EMPLOYEES_URL_TEMPLATE=https://api.recomind.site/api/Team/{team_id}/company/{company_id}
DOTNET_API_TOKEN=

# ===========================================
# Celery & Redis Configuration
# ===========================================
REDIS_HOST=planning-board-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://planning-board-redis:6379/0

CELERY_BROKER_URL=redis://planning-board-redis:6379/0
CELERY_RESULT_BACKEND=redis://planning-board-redis:6379/0
CELERY_QUEUE_NAME=planning_board_queue

# ===========================================
# Rate Limiting & Timeouts
# ===========================================
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
REQUEST_TIMEOUT=120
